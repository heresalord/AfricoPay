# ─── Environnement ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Sécurité interne ─────────────────────────────────────────────────────────
# Clé utilisée par l'app Android pour s'authentifier auprès du backend
AFRICOPAY_API_KEY=changeme_africopay_internal_key

# ─── PayDunya Sandbox ─────────────────────────────────────────────────────────
# Mode : 'sandbox' pour les tests, 'live' pour la production
PAYDUNYA_MODE=sandbox

# Récupérer depuis : https://paydunya.com/integration-setups
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=

# ─── IPN / Webhook ────────────────────────────────────────────────────────────
# URL publique accessible par PayDunya pour envoyer les notifications IPN.
# En développement local, utilisez ngrok : "npx ngrok http 3000"
# Puis renseignez l'URL ngrok ici (ex: https://abc123.ngrok.io)
CALLBACK_BASE_URL=https://xxx.ngrok.io

# ─── Store / Marchand (valeurs par défaut) ────────────────────────────────────
STORE_NAME=AfricoPay POS
STORE_TAGLINE=Votre solution de paiement mobile
